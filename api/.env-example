# Server
PORT=4000
HOST=0.0.0.0

# JWT — change this before deploying anywhere
JWT_SECRET=dev-secret-change-in-production

# PostgreSQL — matches local-deploy/docker-compose.yml defaults
POSTGRESQL_URL=postgres://admin:admin@localhost:5432/deposit-collector?sslmode=disable

# RabbitMQ — matches local-deploy/docker-compose.yml defaults
RABBITMQ_URL=amqp://admin:admin@localhost:5672/

# Observability
METRICS_PORT=9091
DEBUG_LEVEL=debug
