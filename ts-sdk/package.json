{
  "name": "ts-sdk",
  "version": "1.0.0",
  "description": "Typescript SDK for matching engine API",
  "homepage": "https://github.com/Alex99y/matching-engine#readme",
  "bugs": {
    "url": "https://github.com/Alex99y/matching-engine/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alex99y/matching-engine.git"
  },
  "license": "Apache-2.0",
  "author": "Alexander Yammine",
  "type": "module",
  "sideEffects": false,
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    }
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
