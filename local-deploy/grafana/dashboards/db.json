{
  "uid": "me-db",
  "title": "Matching Engine \u2014 Database",
  "tags": [
    "matching-engine",
    "db"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(me_db_pool_connections_open, service)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Connection Pool",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Connections (open / in-use / idle)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "me_db_pool_connections_open{service=~\"$service\"}",
          "legendFormat": "{{service}} open"
        },
        {
          "refId": "B",
          "expr": "me_db_pool_connections_in_use{service=~\"$service\"}",
          "legendFormat": "{{service}} in-use"
        },
        {
          "refId": "C",
          "expr": "me_db_pool_connections_idle{service=~\"$service\"}",
          "legendFormat": "{{service}} idle"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Pool waits (rate) \u2014 exhaustion signal",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service) (rate(me_db_pool_wait_count_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}} waits/s"
        },
        {
          "refId": "B",
          "expr": "sum by (service) (rate(me_db_pool_wait_duration_seconds_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{service}} wait s/s"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "row",
      "title": "Queries",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Query latency by operation (p95)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(me_db_query_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{{operation}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Query rate by operation & result",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (operation, result) (rate(me_db_query_duration_seconds_count{service=~\"$service\"}[1m]))",
          "legendFormat": "{{operation}} {{result}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Query errors by class (per sec)",
      "description": "class=no_rows is a normal lookup miss; exclude it for a true error view.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (operation, class) (rate(me_db_query_errors_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{operation}} {{class}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
